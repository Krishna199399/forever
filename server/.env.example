# Server Environment Variables
# Copy this file to .env and fill in your values

# Server Port
PORT=5000

# Node Environment
NODE_ENV=production

# MongoDB Atlas Connection URI
# Get this from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/forever-us?retryWrites=true&w=majority

# CORS - Set this to your exact frontend domain (no trailing slash)
# Example: https://forevercus.com
CORS_ORIGIN=https://yourdomain.com
